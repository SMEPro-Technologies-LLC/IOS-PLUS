# ============================================================
# IOS+ Environment Variables — Example
# Copy to .env and populate for local development
# NEVER commit .env to version control
# ============================================================

# COS+ Database — per-role connection strings
COS_DB_HOST=localhost
COS_DB_PORT=5432
COS_DB_NAME=ios_plus

DATABASE_URL_IOS_APP=postgresql://ios_app:CHANGE_ME@localhost:5432/ios_plus
DATABASE_URL_AUDIT_WRITER=postgresql://audit_writer:CHANGE_ME@localhost:5432/ios_plus
DATABASE_URL_AUDIT_READER=postgresql://audit_reader:CHANGE_ME@localhost:5432/ios_plus
DATABASE_URL_RAG_READER=postgresql://rag_reader:CHANGE_ME@localhost:5432/ios_plus
DATABASE_URL_RAG_WRITER=postgresql://rag_writer:CHANGE_ME@localhost:5432/ios_plus
DATABASE_URL_COS_ADMIN=postgresql://cos_admin:CHANGE_ME@localhost:5432/ios_plus

COS_DB_PASSWORD_IOS_APP=CHANGE_ME
COS_DB_PASSWORD_AUDIT_WRITER=CHANGE_ME
COS_DB_PASSWORD_AUDIT_READER=CHANGE_ME
COS_DB_PASSWORD_RAG_READER=CHANGE_ME
COS_DB_PASSWORD_RAG_WRITER=CHANGE_ME
COS_DB_PASSWORD_COS_ADMIN=CHANGE_ME

# Redis (Gate 530 session cache)
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME

# HashiCorp Vault (Ed25519 transit engine)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=CHANGE_ME
VAULT_KEY_PATH=transit/keys/ios-evidence-signing

# Gate 530
GATE530_IPC_SOCKET=/tmp/gate530.sock
GATE530_FAIL_CLOSED=true
GATE530_TIMEOUT_MS=50

# Evidence Fabric — gRPC
EVIDENCE_GRPC_PORT=50051
EVIDENCE_KEY_FILESYSTEM_PATH=/etc/ios-plus/keys/current.pub
DNS_TXT_ZONE=_ios-signing-key.smeprotech.com

# RAG Vault — gRPC
RAG_GRPC_PORT=50052
OPENAI_API_KEY=CHANGE_ME

# Middleware Engine
PORT=3000
LOG_LEVEL=debug
NODE_ENV=development

# --- Moonshot Phase 1 Hardening (new env vars) ---

# Quarantine store TTL in milliseconds (default: 86400000 = 24h).
# Parked compliance-review contexts older than this are evicted from Redis.
QUARANTINE_TTL_MS=86400000

# Maximum JSON request body size in bytes for the inference endpoint.
# Requests exceeding this limit receive 413 Payload Too Large.
# Default: 1048576 (1 MiB). Tune via Kubernetes ConfigMap.
MAX_REQUEST_BODY_BYTES=1048576

# Maximum number of simultaneously in-flight requests (per pod).
# Requests beyond this cap receive 503 Service Unavailable with Retry-After.
# Per-pod limit; composes with the HPA for cluster-level backpressure.
# Default: 100.
MAX_INFLIGHT_REQUESTS=100

# Inference endpoint rate limit in requests per second (per pod, token bucket).
# Requests beyond this receive 429 Too Many Requests with Retry-After.
# Default: 50. Document per-pod semantics in runbook when setting this.
RATE_LIMIT_RPS=50

# Maximum raw input length in characters for L1 ingestion.
# Input exceeding this is rejected BEFORE NFKC normalization to avoid
# CPU-bound O(n) normalization on unbounded inputs.
# Default: 1000000 (1 M chars).
MAX_RAW_INPUT_CHARS=1000000

# Admin API key for compliance control-plane routes (/v1/compliance/*).
# Must be set in production; falls back to a dev default in non-production.
COS_ADMIN_API_KEY=CHANGE_ME
