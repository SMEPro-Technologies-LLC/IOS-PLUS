NODE_ENV=development

# Server
PORT=3001
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://iosplus:iosplus@localhost:5432/iosplus
DB_POOL_SIZE=20
DB_SSL_MODE=prefer

# pgvector
PGVECTOR_DIMENSION=1536

# Vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
VAULT_NAMESPACE=
VAULT_TRANSIT_KEY=ios-plus-signing
VAULT_KV_PATH=secret/ios-plus

# Gate 530
GATE530_TRANSPORT=http
GATE530_SOCKET_PATH=/tmp/gate530.sock
GATE530_HTTP2_ENABLED=true
GATE530_MAX_REQUEST_SIZE=10485760

# Evidence Fabric
EVIDENCE_SIGNING_MODE=local
EVIDENCE_PRIVATE_KEY_PATH=./secrets/evidence.pem
EVIDENCE_PUBLIC_KEY_PATH=./secrets/evidence.pub
EVIDENCE_TTL_SECONDS=31536000

# RAG Vault
RAG_VAULT_PARTITION_STRATEGY=uco
RAG_VAULT_DEFAULT_SECTOR=general
RAG_VAULT_MAX_RETRIEVAL_DEPTH=3
RAG_VAULT_EMBEDDING_MODEL=text-embedding-3-large

# COS+
COS_WORM_ENABLED=true
COS_AUDIT_RETENTION_DAYS=2555
COS_ADMIN_JWT_SECRET=change-me-in-production-32-char-min
COS_ADMIN_API_KEY_HASH=

# UCO Resolver
UCO_NAICS_LOOKUP_URL=https://api.census.gov/data/2022/naics
UCO_SOC_CROSSWALK_PATH=db/seeds/soc_naics_crosswalk.csv

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature flags
FF_ADMIN_ROUTES=true
FF_LICENSURE_LOOKUP=true
FF_FAIL_CLOSED=true
