{
  "name": "ios-plus",
  "version": "1.0.0",
  "private": true,
  "description": "IOS+ Middleware Engine & COS+ Database — Compliance-native enforcement and evidence infrastructure for enterprise AI systems",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build --workspaces --if-present",
    "dev": "concurrently \"npm run dev --workspace=packages/middleware-engine\" \"npm run dev --workspace=packages/gate-530\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint packages/**/*.ts",
    "lint:fix": "eslint packages/**/*.ts --fix",
    "format": "prettier --write \"packages/**/*.ts\"",
    "db:migrate": "node scripts/db/migrate.js",
    "db:verify-worm": "node scripts/db/verify-worm.js",
    "db:seed": "node scripts/db/seed.js",
    "db:grant": "psql -f db/grants/apply.sql",
    "helm:lint": "helm lint infra/helm/ios-plus",
    "audit:clean-room": "docker compose -f docker-compose.test.yml up --build --exit-code-from test-runner",
    "release:preflight": "scripts/ops/deploy_orchestration.sh preflight",
    "release:deploy": "scripts/ops/deploy_orchestration.sh deploy"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "@vitest/coverage-v8": "^1.6.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/smeprotech/ios-plus.git"
  },
  "license": "SEE LICENSE IN LICENSE.md"
}
