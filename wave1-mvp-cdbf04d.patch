+name: CD — GCP
+
+on:
+  workflow_dispatch:
+    inputs:
+      environment:
+        description: 'Target environment'
+        required: true
+        default: 'staging'
+        type: choice
+        options:
+          - staging
+          - production
+  push:
+    tags:
+      - 'v*'
+
+env:
+  GCP_PROJECT_ID: ${{ secrets.GCP_PROJECT_ID }}
+  GCP_REGION: ${{ secrets.GCP_REGION }}
+  GAR_REPOSITORY: ${{ secrets.GAR_REPOSITORY }}
+  IMAGE_NAME: ios-plus
+  DELIVERY_PIPELINE: ios-plus-pipeline
+  SKAFFOLD_FILE: ios-plus/infra/cloud-deploy/skaffold.yaml
+
+jobs:
+  determine-environment:
+    name: Determine Environment
+    runs-on: ubuntu-latest
+    outputs:
+      environment: ${{ steps.set-env.outputs.environment }}
+      is_tag: ${{ steps.set-env.outputs.is_tag }}
+    steps:
+      - name: Set environment
+        id: set-env
+        run: |
+          if [ "${{ github.event_name }}" == "workflow_dispatch" ]; then
+            echo "environment=${{ github.event.inputs.environment }}" >> "$GITHUB_OUTPUT"
+            echo "is_tag=false" >> "$GITHUB_OUTPUT"
+          elif [ "${{ github.event_name }}" == "push" ] && [[ "${{ github.ref }}" == refs/tags/v* ]]; then
+            echo "environment=staging" >> "$GITHUB_OUTPUT"
+            echo "is_tag=true" >> "$GITHUB_OUTPUT"
+          else
+            echo "environment=staging" >> "$GITHUB_OUTPUT"
+            echo "is_tag=false" >> "$GITHUB_OUTPUT"
+          fi
+
+  deploy-staging:
+    name: Deploy to Staging
+    runs-on: ubuntu-latest
+    needs: determine-environment
+    if: needs.determine-environment.outputs.environment == 'staging'
+    permissions:
+      contents: read
+      id-token: write
+    environment:
+      name: staging
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v4
+
+      - name: Authenticate to Google Cloud (WIF)
+        uses: google-github-actions/auth@v2
+        with:
+          workload_identity_provider: ${{ secrets.GCP_WORKLOAD_IDENTITY_PROVIDER }}
+          service_account: ${{ secrets.GCP_SERVICE_ACCOUNT }}
+
+      - name: Setup GCP Cloud SDK
+        uses: google-github-actions/setup-gcloud@v2
+        with:
+          project_id: ${{ secrets.GCP_PROJECT_ID }}
+
+      - name: Setup Terraform
+        uses: hashicorp/setup-terraform@v3
+        with:
+          terraform_version: "1.7.0"
+
+      - name: Terraform Init
+        run: terraform init
+        working-directory: ios-plus/infra/terraform
+
+      - name: Terraform Apply — Staging
+        run: terraform apply -auto-approve -var="environment=staging"
+        working-directory: ios-plus/infra/terraform
+
+      - name: Create Cloud Deploy release
+        run: |
+          gcloud deploy releases create "release-${{ github.run_id }}" \
+            --delivery-pipeline="${{ env.DELIVERY_PIPELINE }}" \
+            --region="${{ secrets.GCP_REGION }}" \
+            --images="ios-plus=${{ secrets.GCP_REGION }}-docker.pkg.dev/${{ secrets.GCP_PROJECT_ID }}/${{ secrets.GAR_REPOSITORY }}/${{ env.IMAGE_NAME }}:${{ github.sha }}" \
+            --source="ios-plus/infra/cloud-deploy" \
+            --description="Release ${{ github.sha }}"
+
+      - name: Promote to Staging
+        run: |
+          gcloud deploy releases promote \
+            --release="release-${{ github.run_id }}" \
+            --delivery-pipeline="${{ env.DELIVERY_PIPELINE }}" \
+            --region="${{ secrets.GCP_REGION }}" \
+            --to-target="staging" \
+            --quiet
+
+      - name: Smoke tests — Staging
+        run: |
+          set -e
+          echo "Running smoke tests against staging..."
+          # Health check
+          kubectl run smoke-test --rm -i --restart=Never \
+            --image=curlimages/curl:latest \
+            -- curl -fsS --retry 5 --retry-delay 5 \
+            "https://staging.app.ioscos.com/health" || exit 1
+
+          # Ready check
+          kubectl rollout status deployment/ios-plus -n ios-plus-staging --timeout=300s
+
+          # DB connectivity
+          kubectl run db-smoke --rm -i --restart=Never \
+            --image=postgres:16-alpine \
+            -- psql "$STAGING_DATABASE_URL" -c "SELECT 1;" || exit 1
+
+          # WORM verification
+          kubectl run worm-smoke --rm -i --restart=Never \
+            --image=busybox:1.36 \
+            -- wget -qO- "https://staging.app.ioscos.com/api/v1/worm/status" || exit 1
+        env:
+          STAGING_DATABASE_URL: ${{ secrets.STAGING_DATABASE_URL }}
+
+      - name: Rollback on failure
+        if: failure()
+        run: |
+          echo "Smoke tests failed. Initiating rollback..."
+          gcloud deploy rollbacks start \
+            --release="release-${{ github.run_id }}" \
+            --delivery-pipeline="${{ env.DELIVERY_PIPELINE }}" \
+            --region="${{ secrets.GCP_REGION }}" \
+            --to-target="staging" \
+            --quiet
+
+      # - name: Notify Slack — Success
+      #   if: success()
+      #   uses: slackapi/slack-github-action@v1
+      #   with:
+      #     payload: |
+      #       {"text": "✅ IOS+ deployed to staging: ${{ github.sha }}"}
+      #   env:
+      #     SLACK_WEBHOOK_URL: ${{ secrets.SLACK_WEBHOOK_URL }}
+
+      # - name: Notify Slack — Failure
+      #   if: failure()
+      #   uses: slackapi/slack-github-action@v1
+      #   with:
+      #     payload: |
+      #       {"text": "❌ IOS+ staging deployment FAILED: ${{ github.sha }}"}
+      #   env:
+      #     SLACK_WEBHOOK_URL: ${{ secrets.SLACK_WEBHOOK_URL }}
+
+  deploy-production:
+    name: Deploy to Production
+    runs-on: ubuntu-latest
+    needs: [determine-environment, deploy-staging]
+    if: needs.determine-environment.outputs.environment == 'production'
+    permissions:
+      contents: read
+      id-token: write
+    environment:
