@@ -0,0 +1,302 @@
+# ============================================================================
+# IOS+ Platform — Production Overlay
+# ============================================================================
+# Higher replica counts, stricter resource limits, HPA, PDB, dedicated node
+# selectors, and production-specific labels. All namespaces set to production.
+# ============================================================================
+
+apiVersion: kustomize.config.k8s.io/v1beta1
+kind: Kustomization
+
+namePrefix: prod-
+
+namespace: api-gateway
+
+commonLabels:
+  environment: production
+  cost-center: lamar-cos
+
+commonAnnotations:
+  iosplus.io/environment: "production"
+
+resources:
+  - ../../
+
+patches:
+  # --- api-gateway: 5 replicas, stricter limits, HPA, PDB -------------------
+  - target:
+      kind: Deployment
+      name: ios-plus-api
+    patch: |
+      - op: replace
+        path: /spec/replicas
+        value: 5
+      - op: replace
+        path: /spec/template/spec/containers/0/resources/requests
+        value:
+          cpu: "500m"
+          memory: "512Mi"
+      - op: replace
+        path: /spec/template/spec/containers/0/resources/limits
+        value:
+          cpu: "2000m"
+          memory: "2Gi"
+      - op: replace
+        path: /spec/template/spec/nodeSelector
+        value:
+          cloud.google.com/gke-nodepool: api-gateway-pool
+  - target:
+      kind: HorizontalPodAutoscaler
+      name: ios-plus-api-hpa
+    patch: |
+      - op: replace
+        path: /spec/minReplicas
+        value: 5
+      - op: replace
+        path: /spec/maxReplicas
+        value: 20
+      - op: replace
+        path: /spec/metrics/0/resource/target/averageUtilization
+        value: 70
+  - target:
+      kind: PodDisruptionBudget
+      name: ios-plus-api-pdb
+    patch: |
+      - op: replace
+        path: /spec/minAvailable
+        value: 2
+
+  # --- trust-model: 3 replicas for HA --------------------------------------
+  - target:
+      kind: Deployment
+      name: ios-plus-trust-model
+    patch: |
+      - op: replace
+        path: /spec/replicas
+        value: 3
+      - op: replace
+        path: /spec/template/spec/containers/0/resources/requests
+        value:
+          cpu: "250m"
+          memory: "256Mi"
+      - op: replace
+        path: /spec/template/spec/containers/0/resources/limits
+        value:
+          cpu: "2000m"
+          memory: "2Gi"
+      - op: replace
+        path: /spec/template/spec/nodeSelector
+        value:
+          cloud.google.com/gke-nodepool: trust-model-pool
+
+  # --- connector-ingestion: 5 replicas -------------------------------------
+  - target:
+      kind: Deployment
+      name: ios-plus-connector
+    patch: |
+      - op: replace
+        path: /spec/replicas
+        value: 5
+      - op: replace
+        path: /spec/template/spec/containers/0/resources/requests
+        value:
+          cpu: "250m"
+          memory: "256Mi"
+      - op: replace
+        path: /spec/template/spec/containers/0/resources/limits
+        value:
+          cpu: "2000m"
+          memory: "2Gi"
+      - op: replace
+        path: /spec/template/spec/nodeSelector
