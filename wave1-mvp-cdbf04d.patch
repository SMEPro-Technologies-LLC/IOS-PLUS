+  .inner-block, .middle-block { max-width: 100%; width: 100%; }
+}
+</style>
+</head>
+<body>
+<div class="container">
+  <h1>IOS+ Architecture</h1>
+  <p class="subtitle">Education Compliance Platform — On-Premise Engine with Cloud Source Integration</p>
+
+  <!-- Cloud Sources -->
+  <div class="section-label">
+    <span>Cloud sources</span>
+    <span style="font-size:0.75rem; text-transform:none; font-weight:400;">vendor-hosted · read-only</span>
+  </div>
+  <div class="cloud-row">
+    <div class="cloud-block" onclick="openDetail('banner')">
+      <span class="tag">SIS</span>
+      <h3>Banner</h3>
+      <p>via Ethos</p>
+    </div>
+    <div class="cloud-block" onclick="openDetail('blackboard')">
+      <span class="tag">LMS</span>
+      <h3>Blackboard</h3>
+      <p>engagement</p>
+    </div>
+    <div class="cloud-block" onclick="openDetail('concourse')">
+      <span class="tag">Syllabi</span>
+      <h3>Concourse</h3>
+      <p>syllabi of record</p>
+    </div>
+    <div class="cloud-block" onclick="openDetail('copilot')">
+      <span class="tag">AI</span>
+      <h3>Microsoft Copilot</h3>
+      <p>AI tool governed</p>
+    </div>
+  </div>
+
+  <div class="arrow-down">API connectors · pull / sync</div>
+
+  <!-- IOS+ Engine -->
+  <div class="engine-block">
+    <div class="engine-header">
+      <span>IOS+ engine — on premises</span>
+      <span class="right">data never leaves campus</span>
+    </div>
+    <div class="engine-inner">
+      <div class="inner-block canonical" onclick="openDetail('canonical')">
+        <h4>Canonical layer</h4>
+        <p>one student, one record<br>pseudonymized · SYN</p>
+      </div>
+      <div class="inner-block matrix" onclick="openDetail('matrix')">
+        <h4>Universal Decoding Matrix</h4>
+        <p>CIP · SOC · NAICS · license<br>cited node + policy action</p>
+      </div>
+      <div class="inner-block evidence" onclick="openDetail('evidence')">
+        <h4>Evidence chain</h4>
+        <p>SHA-256 · trace id<br>lineage + audit</p>
+      </div>
+    </div>
+  </div>
+
+  <div class="connector"><div class="connector-line"></div></div>
+
+  <!-- Middle row -->
+  <div class="middle-row">
+    <div class="middle-block copilot-block" onclick="openDetail('copilot-orchestrated')">
+      <h4>Microsoft Copilot, orchestrated by the matrix</h4>
+      <p>answers only from cited nodes</p>
+    </div>
+    <div class="middle-block live-block" onclick="openDetail('live-check')">
+      <h4>Live check at query time</h4>
+      <p>confirms node, or flags change<br>regulatory lookup only — no PII</p>
+    </div>
+  </div>
+
+  <div class="connector"><div class="connector-line"></div></div>
+
+  <!-- EDU Reporter -->
+  <div class="reporter-block" onclick="openDetail('reporter')">
+    <h3>EDU Reporter</h3>
+    <p>monitored filings — IPEDS · CBM · NSLDS · FISAP · Clery<br>operational views + degree-plan-to-licensure lookup</p>
