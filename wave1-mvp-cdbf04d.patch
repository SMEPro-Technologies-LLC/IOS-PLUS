+</div>
+
+<!-- Detail Overlay -->
+<div class="detail-overlay" id="detailOverlay" onclick="closeDetail(event)">
+  <div class="detail-panel" id="detailPanel" onclick="event.stopPropagation()">
+    <button class="close-btn" onclick="closeDetail()">&times;</button>
+    <div id="detailContent"></div>
+  </div>
+</div>
+
+<script>
+const details = {
+  banner: {
+    title: 'Banner via Ethos',
+    meta: 'Student Information System (SIS) Integration',
+    body: `
+      <p>Banner by Ellucian is the primary student information system. The Ethos integration platform provides:</p>
+      <ul>
+        <li><strong>API Connectors:</strong> RESTful APIs for student records, enrollment, and academic history</li>
+        <li><strong>Pull/Sync:</strong> Scheduled ETL jobs to synchronize student data into the canonical layer</li>
+        <li><strong>Pseudonymization:</strong> Student PII is hashed before entering the IOS+ engine</li>
+        <li><strong>Read-only:</strong> No write-back to Banner; all mutations flow through the canonical layer</li>
+        <li><strong>Data:</strong> Student demographics, enrollment status, degree plans, academic standing, transcripts</li>
+      </ul>
+      <p><strong>Sync frequency:</strong> Every 15 minutes during business hours, hourly overnight.</p>
+    `
+  },
+  blackboard: {
+    title: 'Blackboard Engagement',
+    meta: 'Learning Management System (LMS) Integration',
+    body: `
+      <p>Blackboard Learn provides engagement and activity data for compliance monitoring:</p>
+      <ul>
+        <li><strong>Course engagement:</strong> Login frequency, time-on-task, assignment submission rates</li>
+        <li><strong>Academic activity:</strong> Discussion participation, assessment completion, grade progression</li>
+        <li><strong>Attendance proxy:</strong> LMS activity as a proxy for attendance verification</li>
+        <li><strong>Retention signals:</strong> Early warning indicators for SAP (Satisfactory Academic Progress)</li>
+      </ul>
+      <p>Data is anonymized via the canonical layer before entering the UDM for analysis.</p>
+    `
+  },
+  concourse: {
+    title: 'Concourse Syllabi of Record',
+    meta: 'Curriculum Management & Syllabus Repository',
+    body: `
+      <p>Concourse manages the official syllabi of record for regulatory compliance:</p>
+      <ul>
+        <li><strong>Syllabi of Record:</strong> Official course descriptions tied to CIP codes for Title IV compliance</li>
+        <li><strong>Learning Outcomes:</strong> Measurable outcomes mapped to SOC/NAICS occupational requirements</li>
+        <li><strong>Curriculum Alignment:</strong> Course content verification against state licensure prerequisites</li>
+        <li><strong>Audit Trail:</strong> Every syllabus revision is timestamped and signed in the evidence chain</li>
+      </ul>
+      <p>Syllabus data feeds the UDM to validate that programs prepare students for licensure.</p>
+    `
+  },
+  copilot: {
+    title: 'Microsoft Copilot',
+    meta: 'Governed AI Assistant — Read-Only Cloud Source',
+    body: `
+      <p><strong>Microsoft Copilot</strong> is a vendor-hosted AI tool that acts as a read-only cloud source into the IOS+ engine:</p>
+      <ul>
+        <li><strong>Governed Mode:</strong> All Microsoft Copilot responses are constrained by the Universal Decoding Matrix</li>
+        <li><strong>Query Log:</strong> Every Copilot query is logged in the evidence chain with SHA-256 signatures</li>
+        <li><strong>Answer Sourcing:</strong> Copilot answers only from cited nodes in the UDM — no hallucination</li>
+        <li><strong>Compliance Filter:</strong> PHI/PII is blocked at the canonical layer before reaching Microsoft Copilot</li>
+        <li><strong>Microsoft Graph Integration:</strong> Operates within the institution's Microsoft 365 tenant boundary</li>
+      </ul>
+      <p>Microsoft Copilot is <strong>not</strong> a source of truth. It is an interface layer that queries the IOS+ engine.</p>
+    `
+  },
+  canonical: {
+    title: 'Canonical Layer',
+    meta: 'One Student · One Record · Pseudonymized · SYN',
+    body: `
+      <p>The canonical layer is the single source of truth for student data within the IOS+ engine:</p>
+      <ul>
+        <li><strong>One Student, One Record:</strong> Deduplicates data from Banner, Blackboard, and other sources into a unified student profile</li>
+        <li><strong>Pseudonymization:</strong> All PII is hashed using SHA-256 with a campus-specific salt. The original ID is never stored in the engine.</li>
+        <li><strong>SYN (Synthetic Identifier):</strong> Each student is assigned a synthetic UUID that is consistent across all downstream systems</li>
+        <li><strong>Data Governance:</strong> Field-level provenance tracking — every value knows its source system and last sync time</li>
+        <li><strong>Change Detection:</strong> Differential sync detects changes at the source and triggers downstream re-evaluation</li>
+      </ul>
+      <p>The canonical layer ensures that no student PII ever leaves the campus network. All external-facing queries operate on pseudonymized identifiers.</p>
+      <div class="endpoint">POST /v1/canonical/resolve — resolve SYN to internal record</div>
+    `
+  },
+  matrix: {
+    title: 'Universal Decoding Matrix (UDM)',
+    meta: 'CIP · SOC · NAICS · License — Cited Node + Policy Action',
+    body: `
+      <p>The UDM is the governed ontology that maps educational programs to licensure requirements:</p>
+      <ul>
+        <li><strong>CIP (Classification of Instructional Programs):</strong> NCES taxonomy of educational programs (e.g., 51.3801 = Registered Nursing)</li>
+        <li><strong>SOC (Standard Occupational Classification):</strong> BLS taxonomy of occupations (e.g., 29-1141 = Registered Nurses)</li>
+        <li><strong>NAICS (North American Industry Classification):</strong> Census taxonomy of industries (e.g., 621111 = Offices of Physicians)</li>
+        <li><strong>License:</strong> State-level regulatory obligations from uco_obligation_metadata</li>
+        <li><strong>Cited Node:</strong> Every UDM traversal produces a cited node with provenance and confidence score</li>
+        <li><strong>Policy Action:</strong> Gate 530 evaluates each traversal against compliance policies before returning results</li>
+      </ul>
+      <p><strong>Traversal Paths:</strong></p>
+      <ul>
+        <li>Direct: <code>CIP → NAICS → State Obligation</code></li>
+        <li>Two-hop: <code>CIP → SOC → NAICS → State Obligation</code></li>
+      </ul>
+      <p><strong>Ranking:</strong> Direct matches first, then by confidence (descending), then by risk (ascending).</p>
+      <div class="endpoint">GET /v1/compliance/licensure/state-lookup?student_cip=51.3801&destination_state=CA</div>
+    `
+  },
+  evidence: {
+    title: 'Evidence Chain',
+    meta: 'SHA-256 · Trace ID · Lineage + Audit',
+    body: `
+      <p>Every decision in the IOS+ engine is cryptographically signed and auditable:</p>
+      <ul>
+        <li><strong>SHA-256 Hashing:</strong> Every evidence record includes a SHA-256 hash of its canonical payload</li>
+        <li><strong>Trace ID:</strong> Every request is assigned a trace ID that propagates through all layers for end-to-end lineage</li>
+        <li><strong>Ed25519 Signing:</strong> Evidence records are signed with Ed25519 keys (local or Vault Transit)</li>
+        <li><strong>JCS Canonicalization:</strong> Payloads are canonicalized per RFC 8785 before signing to ensure deterministic verification</li>
+        <li><strong>Chain Integrity:</strong> Each evidence record includes the previous record's hash, creating an immutable chain</li>
+        <li><strong>WORM Enforcement:</strong> Audit tables are protected by PostgreSQL triggers that block UPDATE and DELETE</li>
+        <li><strong>Triple Publication:</strong> Evidence is verified against three independent publication keys for cryptographic assurance</li>
+      </ul>
+      <p><strong>Retention:</strong> 7 years (2555 days) for audit events and evidence records per regulatory requirements.</p>
+      <div class="endpoint">GET /v1/evidence/:requestId — retrieve signed evidence record</div>
+    `
+  },
+  'copilot-orchestrated': {
+    title: 'Microsoft Copilot, Orchestrated by the Matrix',
+    meta: 'Answers Only from Cited Nodes',
+    body: `
+      <p><strong>Microsoft Copilot</strong> is orchestrated by the Universal Decoding Matrix to ensure all AI responses are grounded in cited evidence:</p>
+      <ul>
+        <li><strong>Cited Node Constraint:</strong> Microsoft Copilot can only generate answers from nodes that have been explicitly cited and verified by the UDM</li>
+        <li><strong>Source Grounding:</strong> Every answer includes the citation ID, UDM path, and confidence score of the underlying data</li>
+        <li><strong>Policy Gate:</strong> Gate 530 evaluates every Copilot query before execution — denied queries return a structured compliance error</li>
+        <li><strong>No PII:</strong> Microsoft Copilot operates on pseudonymized data; it never sees real student names, SSNs, or other PII</li>
+        <li><strong>Evidence Logging:</strong> Every Copilot query and response is logged in the evidence chain with a trace ID</li>
+        <li><strong>Tenant Isolation:</strong> Runs within the institution's Microsoft 365 tenant; data does not leave campus boundaries</li>
+      </ul>
+      <p>This architecture prevents AI hallucination by constraining Microsoft Copilot to only use verified, cited data from the UDM.</p>
+    `
+  },
+  'live-check': {
+    title: 'Live Check at Query Time',
+    meta: 'Confirms Node, or Flags Change — Regulatory Lookup Only, No PII',
+    body: `
+      <p>Every query triggers a live compliance check against current regulatory data:</p>
+      <ul>
+        <li><strong>Node Confirmation:</strong> The UDM verifies that the cited node is still valid (not expired, not revoked)</li>
+        <li><strong>Change Detection:</strong> If a state licensure requirement has changed since the last sync, the live check flags it</li>
+        <li><strong>Regulatory Lookup Only:</strong> The live check queries only regulatory metadata — no student PII is involved</li>
+        <li><strong>Fail-Closed:</strong> If the live check cannot confirm a node (e.g., API down), the system defaults to DENY with an escalation reason</li>
+        <li><strong>Cache Strategy:</strong> Regulatory data is cached for 24 hours; stale data triggers a background refresh</li>
+        <li><strong>Alerting:</strong> Changes in licensure requirements trigger alerts to compliance officers via the monitoring stack</li>
+      </ul>
+      <p>The live check ensures that answers are always based on the most current regulatory landscape, not stale cached data.</p>
+    `
+  },
+  reporter: {
+    title: 'EDU Reporter',
+    meta: 'Monitored Filings — Operational Views + Degree-Plan-to-Licensure Lookup',
+    body: `
+      <p>EDU Reporter is the compliance reporting and filing engine for higher education regulatory requirements:</p>
+      <ul>
+        <li><strong>IPEDS (Integrated Postsecondary Education Data System):</strong> Annual and fall/spring data collection submissions</li>
+        <li><strong>CBM (Consolidated Budget and Reporting):</strong> State-level budget and enrollment reporting</li>
+        <li><strong>NSLDS (National Student Loan Data System):</strong> Enrollment reporting and roster submission</li>
+        <li><strong>FISAP (Fiscal Operations Report):</strong> Federal student aid fiscal operations</li>
+        <li><strong>Clery Act:</strong> Campus safety and crime statistics reporting</li>
+      </ul>
+      <p><strong>Operational Views:</strong></p>
+      <ul>
+        <li>Degree-plan-to-licensure lookup: For each active degree plan, show the licensure requirements in all 50 states</li>
+        <li>SAP monitoring: Satisfactory Academic Progress tracking with early warning alerts</li>
+        <li>Enrollment verification: Real-time enrollment status for Title IV compliance</li>
+        <li>Program review dashboard: CIP-to-NAICS alignment with licensure coverage scores</li>
+      </ul>
+      <p>All reports are generated from the canonical layer with evidence-backed data lineage for audit defense.</p>
+      <div class="endpoint">GET /v1/reports/degree-plan-licensure — licensure coverage by degree plan</div>
+    `
+  }
+};
+
+function openDetail(key) {
+  const d = details[key];
+  if (!d) return;
+  document.getElementById('detailContent').innerHTML = 
+    '<h2>' + d.title + '</h2>' +
+    '<div class="meta">' + d.meta + '</div>' +
+    d.body;
+  document.getElementById('detailOverlay').classList.add('active');
+  document.body.style.overflow = 'hidden';
+}
+
+function closeDetail(e) {
+  if (e && e.target !== document.getElementById('detailOverlay')) return;
+  document.getElementById('detailOverlay').classList.remove('active');
+  document.body.style.overflow = '';
+}
+</script>
+</body>
+</html>
