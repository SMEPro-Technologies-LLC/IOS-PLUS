+  flex-wrap: wrap;
+}
+.inner-block {
+  border-radius: 12px;
+  padding: 20px 24px;
+  min-width: 220px;
+  max-width: 300px;
+  text-align: center;
+  cursor: pointer;
+  transition: all 0.25s ease;
+  position: relative;
+}
+.inner-block:hover {
+  transform: translateY(-3px);
+  box-shadow: var(--shadow-hover);
+}
+.inner-block h4 { font-size: 1rem; margin-bottom: 6px; }
+.inner-block p { font-size: 0.8rem; line-height: 1.5; }
+
+.canonical { background: #eef8e8; border: 1.5px solid #c5e1a5; }
+.canonical:hover { border-color: #9ccc65; }
+.canonical h4 { color: #558b2f; }
