+  max-width: 420px;
+  text-align: center;
+  cursor: pointer;
+  transition: all 0.25s ease;
+}
+.middle-block:hover {
+  transform: translateY(-3px);
+  box-shadow: var(--shadow-hover);
+}
+.middle-block h4 { font-size: 1rem; margin-bottom: 6px; }
+.middle-block p { font-size: 0.8rem; line-height: 1.5; }
+
+.copilot-block { background: var(--copilot-bg); border: 1.5px solid var(--copilot-border); }
+.copilot-block:hover { border-color: #b39ddb; }
+.copilot-block h4 { color: #5e35b1; }
+.live-block { background: var(--live-bg); border: 1.5px solid var(--live-border); }
+.live-block:hover { border-color: #e6c35c; }
+.live-block h4 { color: #8d6e00; }
+
+/* Reporter block */
+.reporter-block {
+  background: var(--reporter-bg);
+  border: 2px solid var(--reporter-border);
+  border-radius: 16px;
+  padding: 24px;
+  text-align: center;
+  cursor: pointer;
+  transition: all 0.25s ease;
+}
+.reporter-block:hover {
+  transform: translateY(-3px);
+  box-shadow: var(--shadow-hover);
+  border-color: #81c784;
+}
+.reporter-block h3 { color: #2e7d32; font-size: 1.1rem; margin-bottom: 8px; }
+.reporter-block p { color: var(--text-muted); font-size: 0.85rem; line-height: 1.6; }
+
+/* Footer */
+.footer {
+  display: flex;
+  justify-content: space-between;
+  margin-top: 24px;
+  font-size: 0.75rem;
+  color: var(--text-muted);
+  font-style: italic;
+}
+
+/* Detail panel */
+.detail-overlay {
+  position: fixed;
+  top: 0; left: 0; right: 0; bottom: 0;
+  background: rgba(0,0,0,0.4);
+  display: none;
+  justify-content: center;
+  align-items: center;
+  z-index: 1000;
