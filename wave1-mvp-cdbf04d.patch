+          env:
+            - name: GF_SECURITY_ADMIN_USER
+              valueFrom:
+                secretKeyRef:
+                  name: ios-plus-grafana-secrets
+                  key: admin-user
+            - name: GF_SECURITY_ADMIN_PASSWORD
+              valueFrom:
+                secretKeyRef:
+                  name: ios-plus-grafana-secrets
+                  key: admin-password
+            - name: GF_AUTH_GOOGLE_ENABLED
+              value: "true"
+            - name: GF_AUTH_GOOGLE_ALLOW_SIGN_UP
+              value: "true"
+            - name: GF_AUTH_GOOGLE_CLIENT_ID
+              valueFrom:
