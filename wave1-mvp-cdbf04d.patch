+# ------------------------------------------------------------------------
+# Wave 1 MVP — Local End-to-End Stack
+# Minimal deployable unit: gate-530 API + PostgreSQL (pgvector)
+# No Vault, Prometheus, or Grafana — just the core value loop
+# ------------------------------------------------------------------------
+
+services:
+  gate-530-api:
+    build:
+      context: ../..
+      dockerfile: packages/gate-530/Dockerfile
+      target: production
+    container_name: ios-plus-gate-530-api
+    ports:
+      - "3001:3001"
+    environment:
+      - NODE_ENV=production
+      - PORT=3001
+      - HOST=0.0.0.0
+      - DATABASE_URL=postgresql://iosplus:iosplus@postgres:5432/iosplus
+      - JWT_SECRET=wave1-mvp-local-dev-secret-do-not-use-in-production
+      - JWT_ISSUER=ios-plus-wave1
+      - EVIDENCE_PRIVATE_KEY_PATH=/data/keys/evidence.key
+      - CORS_ORIGINS=*
+      - RATE_LIMIT_MAX_REQUESTS=1000
+    volumes:
+      - gate530_keys:/data/keys
+    depends_on:
+      postgres:
+        condition: service_healthy
+      db-migrations:
+        condition: service_completed_successfully
+    networks:
+      - ios-plus-wave1
+    healthcheck:
+      test: ["CMD", "curl", "-f", "http://localhost:3001/ready"]
+      interval: 30s
+      timeout: 10s
+      retries: 3
+      start_period: 15s
+
+  postgres:
+    image: pgvector/pgvector:pg16
+    container_name: ios-plus-postgres-wave1
+    ports:
+      - "5432:5432"
+    environment:
+      POSTGRES_USER: iosplus
+      POSTGRES_PASSWORD: iosplus
+      POSTGRES_DB: iosplus
+    volumes:
+      - postgres_wave1_data:/var/lib/postgresql/data
+      - ../../db/init:/docker-entrypoint-initdb.d
+    networks:
+      - ios-plus-wave1
+    healthcheck:
+      test: ["CMD-SHELL", "pg_isready -U iosplus -d iosplus"]
+      interval: 5s
+      timeout: 5s
+      retries: 10
+      start_period: 5s
+
+  db-migrations:
+    image: pgvector/pgvector:pg16
+    container_name: ios-plus-migrations-wave1
+    environment:
+      PGHOST: postgres
+      PGUSER: iosplus
+      PGPASSWORD: iosplus
+      PGDATABASE: iosplus
+    volumes:
+      - ../../db/migrations:/migrations
+    command: >
+      sh -c "
+        sleep 5 &&
+        psql -f /migrations/001_initial_schema.sql &&
+        psql -f /migrations/002_worm_triggers.sql &&
+        psql -f /migrations/003_indexes.sql &&
+        psql -f /migrations/006_seed_data.sql
+      "
+    depends_on:
+      postgres:
+        condition: service_healthy
+    networks:
+      - ios-plus-wave1
+    restart: "no"
+
+networks:
+  ios-plus-wave1:
+    driver: bridge
+
+volumes:
+  postgres_wave1_data:
+  gate530_keys:
