+  selector:
+    matchLabels:
+      app.kubernetes.io/name: ios-plus-grafana
+  template:
+    metadata:
+      labels:
+        app.kubernetes.io/name: ios-plus-grafana
+        app.kubernetes.io/component: monitoring
+        app.kubernetes.io/version: "10.4.3"
+        cost-center: lamar-cos
+    spec:
+      serviceAccountName: ios-plus-monitoring-sa
+      automountServiceAccountToken: false
+      securityContext:
+        runAsNonRoot: true
