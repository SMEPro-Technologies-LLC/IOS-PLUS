+        <li><strong>Detection:</strong> Firecrawl + API polling for changes</li>
+        <li><strong>Approval gate:</strong> Proposed updates require human approval before deployment</li>
+        <li><strong>Output:</strong> Change log, impact assessment, proposed rule updates</li>
+      </ul>
+      <p><strong>Value:</strong> Never surprised by a regulatory change again</p>
+    `
+  },
+  'edu-reporter': {
+    title: 'EDU Reporter',
+    meta: 'Reporting Surface for All Use Cases',
+    body: `
+      <p><strong>Product layer:</strong> Unified reporting interface</p>
+      <ul>
+        <li><strong>Dashboards:</strong> Predictive Persistence, Transcript Eval, Accreditation Heat Map, Drift Detection, Grading Load, Allied Health, Regulatory Watchtower</li>
+        <li><strong>Monitored filings:</strong> IPEDS, CBM, NSLDS, FISAP, Clery</li>
+        <li><strong>Operational views:</strong> Degree-plan-to-licensure lookup, SAP monitoring, enrollment verification</li>
+        <li><strong>Evidence access:</strong> One-click drill-down to supporting evidence for every reported number</li>
+      </ul>
+      <p>EDU Reporter is the surface. IOS+ is the engine underneath.</p>
+    `
+  }
+};
+
+function openDetail(key) {
+  const d = details[key];
+  if (!d) return;
+  document.getElementById('detailContent').innerHTML = 
+    '<h2>' + d.title + '</h2>' +
+    '<div class="meta">' + d.meta + '</div>' +
+    d.body;
+  document.getElementById('detailOverlay').classList.add('active');
+  document.body.style.overflow = 'hidden';
+}
+
+function closeDetail(e) {
+  if (e && e.target !== document.getElementById('detailOverlay')) return;
+  document.getElementById('detailOverlay').classList.remove('active');
+  document.body.style.overflow = '';
+}
+</script>
+</body>
+</html>
